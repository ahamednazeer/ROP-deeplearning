# ─────────────────────────────────────────────────────────────
# ROP Detection API – Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────

# JWT signing secret – change this to a long random string in production!
SECRET_KEY=your-super-secret-key-change-in-production

# Path to the pre-trained Keras model (.h5 file).
# Relative paths are resolved from the ml/inference.py location.
MODEL_PATH=../best_rop_model.h5

# SQLAlchemy database URL.
# SQLite (default):
DATABASE_URL=sqlite:///./rop.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/rop_db
